.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/
.idea/
*.swp
*.swo
*~

# Node modules (si usas npm/node en el futuro)
node_modules/
package-lock.json
# El lockfile de la app SÍ se versiona: npm ci en el workflow de deploy
# necesita builds reproducibles.
!app/package-lock.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# Archivos temporales
*.log
*.tmp
.cache/

# Output del scrape de portadas: viaja como artifact o en la rama
# scrape-covers-test (el workflow hace git add -f), nunca a main.
data/covers.json

# Output del sondeo de páginas de tag: viaja solo como artifact.
probe_out/

# Output del scraper de descubrimiento: los candidatos entran al repo
# solo vía PR revisable (git add -f deliberado, como covers.json) y el
# estado viaja como artifact o en rama de estado. data/rejected.json y
# data/tag_candidates.json SÍ se versionan.
data/candidates_*.json
data/discovery_state.json

# Build outputs (para futuras compilaciones)
dist/
build/

# Variables de entorno
.env
.env.local
